# =============================================================================
# Şablon: köke kopyala →  .env
#   cp env.sample .env
# PASTE_... değerlerini doldur. .env’i asla commit etme.
#
# Demo giriş (uygulama): kullanıcı adı admin  ·  şifre 12345678
# Supabase’te kullanıcı eklerken e-posta: admin@memeops.local
# (Uygulama yalnızca "admin" yazar; arka planda bu adres kullanılır.)
# Giriş hata verirse: uygulamada «İlk kurulum: kayıt oluştur» veya Dashboard → Users.
# Geliştirmede: Authentication → Providers → «Confirm email» kapat (anında giriş için).
#
# Flutter: assets/env/bootstrap.env önce yüklenir, sonra bu dosya (kök .env) birleşir.
# TELEGRAM_* anahtarları mobilde bilinçli silinir — sadece ./run_telegram_api.sh (Python) okur.
# =============================================================================

# --- Telegram: uygulamadan kanala görsel (Bot API sendPhoto) ---
# Botu her hedef kanala admin olarak ekleyin (mesaj gönderme). Token’ı commit etmeyin.
TELEGRAM_PUBLISH_BOT_TOKEN=
# Tek kanal (eski): yalnızca TELEGRAM_PUBLISH_CHANNELS_JSON boşsa kullanılır.
TELEGRAM_PUBLISH_CHANNEL=@memasicspace
# Çoklu kanal: TEK SATIR JSON. id = @kanal veya -100… ; label = açıklama; bot_token = isteğe bağlı, o satır o bot ile yayın (her kanalda o bot yönetici);
# boş [bot_token] → TELEGRAM_PUBLISH_BOT_TOKEN kullanılır. kw = virgülle (metin+başlık eşleşince «Önerilen»).
# Örnek (kendi @ ve kelimelerinle değiştir):
# TELEGRAM_PUBLISH_CHANNELS_JSON=[{"id":"-1001234567890","label":"Okul","bot_token":"","kw":"okul,öğretmen,ders,exam"},{"id":"@genel","label":"AI","bot_token":"123:ABC...","kw":"yapay zeka,ai,gpt"}]
TELEGRAM_PUBLISH_CHANNELS_JSON=

# --- VK: paylaş → alttan «ВКонтакте» (grup duvarı) ---
# ÖNEM: Topluluk (gizli) access token ile fotoğraf yükleyemezsin; VK "group auth" hatası verir.
# Kullanıcı token almak: köke VK_APP_ID=... yaz, ./setup_vk_user_token.sh çalıştır, token’ı VK_USER_ACCESS_TOKEN’a yapıştır.
# Uygulama ayarlarında "Доверенный redirect" içinde https://oauth.vk.com/blank.html olmalı.
VK_APP_ID=
# (İsteğe bağlı) Kullanıcı OAuth access token: wall, photos, video, groups, offline. Doluysa tüm API bu token’ı kullanır.
VK_USER_ACCESS_TOKEN=
# Geçmiş uyumluluk: sadece kullanıcı token’ı koyacaksan VK_USER boş, bunu doldur.
VK_ACCESS_TOKEN=
# Sayısal grup id: vk.com/club<ID> (ör. 123456). Boş: yalnızca Telegram/tek hedef.
VK_GROUP_ID=

# --- Supabase (Flutter + Python API; public anon key) ---
SUPABASE_URL=PASTE_https://xxxxx.supabase.co
SUPABASE_ANON_KEY=PASTE_supabase_anon_key

# MemeOps HTTP tabanı (Flutter → aynı portta Python API)
# Android emülatör: AppEnv 127.0.0.1 → 10.0.2.2 çevirir; fiziksel cihazda PC IP yaz.
MEMEOPS_API_BASE=http://127.0.0.1:3000

# 1 = gömülü Dart stub :3000 kullanılmaz; ./run_telegram_api.sh beklenir
MEMEOPS_USE_PYTHON_API=1

# Python sunucu portu (run_telegram_api.sh); MEMEOPS_API_BASE ile aynı port
TELEGRAM_INSIGHTS_PORT=3000

# --- Telegram (yalnızca kök .env + ./run_telegram_api.sh; Flutter bundle’a gitmez) ---
# https://my.telegram.org/apps
TELEGRAM_API_ID=PASTE_integer_api_id
TELEGRAM_API_HASH=PASTE_api_hash_string
# ./setup_telegram_session.sh veya telethon_create_string_session.py
TELEGRAM_SESSION_STRING=PASTE_session_string

# --- OpenAI (yalnızca Python API: metin + görsel) ---
OPENAI_API_KEY=PASTE_sk_openai_key

# İsteğe bağlı model / kalite (boş = hızlı varsayılanlar: mini + low)
OPENAI_TEXT_MODEL=gpt-4o-mini
# Hız: gpt-image-1-mini | Daha güçlü: gpt-image-1 veya gpt-image-1.5
OPENAI_IMAGE_MODEL=gpt-image-1-mini
# low = en hızlı; medium/high = daha yavaş ve pahalı
OPENAI_IMAGE_QUALITY=low
# 1024x1024 | 1024x1536 | 1536x1024 | auto
OPENAI_IMAGE_SIZE=1024x1024
# GPT Image: moderation low = daha az sıkı (genelde daha az bekleme)
OPENAI_IMAGE_MODERATION=low
# Tek görsel OpenAI okuma üst sınırı (sn). Boş = 900 (15 dk). Kısa süre Connection error üretebilir.
OPENAI_IMAGE_READ_TIMEOUT=900
OPENAI_VISION_MODEL=gpt-4o-mini

# --- OpenAI Sora 2 (video) ---
# Model: sora-2 (hızlı/uygun) veya sora-2-pro (daha yüksek kalite, pahalı)
OPENAI_VIDEO_MODEL=sora-2
# sora-2 yalnızca 1280x720 veya 720x1280 destekler. Dikey (kısa video gibi): 720x1280
OPENAI_VIDEO_SIZE=720x1280
# Sora işi polling üst sınırı (sn). Boş = 900 (15 dk).
OPENAI_VIDEO_READ_TIMEOUT=900
